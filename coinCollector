function drawCoin(c){
  ctx.save();ctx.translate(c.x,c.y);
  const pulse=1+Math.sin(c.age*3.5)*0.08;
  if(c.type==='square'){
    const beat=1+Math.sin(c.age*3.5)*0.1,hue=(t*90)%360;
    ctx.rotate(c.age*1.4);ctx.shadowColor=`hsl(${hue},100%,65%)`;ctx.shadowBlur=36;
    const s=c.r*beat;ctx.fillStyle=`hsla(${hue},100%,65%,0.12)`;ctx.fillRect(-s*1.4,-s*1.4,s*2.8,s*2.8);
    const g=ctx.createLinearGradient(-s,-s,s,s);g.addColorStop(0,`hsl(${hue},100%,75%)`);g.addColorStop(0.5,'#fff');g.addColorStop(1,`hsl(${(hue+180)%360},100%,55%)`);
    ctx.fillStyle=g;const rad=s*0.22;
    ctx.beginPath();ctx.moveTo(-s+rad,-s);ctx.lineTo(s-rad,-s);ctx.arcTo(s,-s,s,-s+rad,rad);ctx.lineTo(s,s-rad);ctx.arcTo(s,s,s-rad,s,rad);ctx.lineTo(-s+rad,s);ctx.arcTo(-s,s,-s,s-rad,rad);ctx.lineTo(-s,-s+rad);ctx.arcTo(-s,-s,-s+rad,-s,rad);ctx.closePath();ctx.fill();
    ctx.strokeStyle=`hsl(${(hue+60)%360},100%,90%)`;ctx.lineWidth=2.5;ctx.stroke();
    ctx.rotate(-c.age*1.4);ctx.shadowBlur=0;ctx.fillStyle='#fff';ctx.font=`bold ${s*.58}px "Segoe UI"`;ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText('1000',0,0);
  }else if(c.type==='bigstar'){
    const beat=1+Math.sin(c.age*4)*0.13,hue=(t*80)%360;
    ctx.shadowColor=`hsl(${hue},100%,65%)`;ctx.shadowBlur=40;
    ctx.beginPath();ctx.arc(0,0,c.r*beat*1.45,0,pi2);ctx.fillStyle=`hsla(${hue},100%,65%,0.12)`;ctx.fill();
    ctx.beginPath();for(let i=0;i<16;i++){const a=i*Math.PI/8+t*1.2,r2=i%2===0?c.r*beat:c.r*beat*0.48;i===0?ctx.moveTo(Math.cos(a)*r2,Math.sin(a)*r2):ctx.lineTo(Math.cos(a)*r2,Math.sin(a)*r2);}ctx.closePath();
    const sg=ctx.createRadialGradient(0,0,2,0,0,c.r*beat);sg.addColorStop(0,'#fff');sg.addColorStop(0.3,`hsl(${hue},100%,75%)`);sg.addColorStop(0.7,`hsl(${(hue+90)%360},100%,55%)`);sg.addColorStop(1,`hsl(${(hue+180)%360},100%,40%)`);
    ctx.fillStyle=sg;ctx.fill();ctx.strokeStyle=`hsl(${(hue+60)%360},100%,85%)`;ctx.lineWidth=2;ctx.stroke();
    ctx.shadowBlur=0;ctx.fillStyle='#fff';ctx.font=`bold ${c.r*.62}px "Segoe UI"`;ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText('500',0,0);
  }else if(c.type==='green'){
    ctx.shadowColor='#00c853';ctx.shadowBlur=14;const r=c.r*pulse;
    const g=ctx.createRadialGradient(-r*.3,-r*.3,r*.1,0,0,r);g.addColorStop(0,'#ccff90');g.addColorStop(.45,'#69f0ae');g.addColorStop(1,'#00695c');
    ctx.fillStyle=g;ctx.beginPath();ctx.arc(0,0,r,0,pi2);ctx.fill();
    ctx.shadowBlur=0;ctx.fillStyle='rgba(255,255,255,0.48)';ctx.beginPath();ctx.ellipse(-r*.22,-r*.28,r*.32,r*.18,-0.45,0,pi2);ctx.fill();
    ctx.fillStyle='rgba(0,50,20,0.85)';ctx.font=`bold ${r*1.1}px serif`;ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText('G',0,1);
  }else if(c.type==='purple'){
    ctx.shadowColor='#aa00ff';ctx.shadowBlur=16;const r=c.r*pulse;
    const g=ctx.createRadialGradient(-r*.3,-r*.3,r*.1,0,0,r);g.addColorStop(0,'#e1bee7');g.addColorStop(.45,'#ce93d8');g.addColorStop(1,'#6a0080');
    ctx.fillStyle=g;ctx.beginPath();ctx.arc(0,0,r,0,pi2);ctx.fill();
    ctx.shadowBlur=0;ctx.fillStyle='rgba(255,255,255,0.48)';ctx.beginPath();ctx.ellipse(-r*.22,-r*.28,r*.32,r*.18,-0.45,0,pi2);ctx.fill();
    ctx.fillStyle='rgba(40,0,60,0.85)';ctx.font=`bold ${r*1.1}px serif`;ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText('P',0,1);
  }else if(c.type==='star'){
    ctx.shadowColor=`hsl(${(t*100)%360},100%,65%)`;ctx.shadowBlur=22;
    star5(0,0,c.r*1.3*pulse,c.r*0.55*pulse,5,t*2.2);
    const hue=(t*100)%360;ctx.fillStyle=`hsl(${hue},100%,68%)`;ctx.fill();ctx.strokeStyle=`hsl(${(hue+70)%360},100%,85%)`;ctx.lineWidth=1.5;ctx.stroke();
    ctx.shadowBlur=0;ctx.fillStyle='rgba(255,255,255,0.55)';ctx.beginPath();ctx.ellipse(-c.r*.25,-c.r*.35,c.r*.28,c.r*.15,-0.4,0,pi2);ctx.fill();
  }else{
    ctx.shadowColor='#ffc107';ctx.shadowBlur=14;const r=c.r*pulse;
    const g=ctx.createRadialGradient(-r*.3,-r*.3,r*.1,0,0,r);g.addColorStop(0,'#fff9c4');g.addColorStop(.45,'#ffd600');g.addColorStop(1,'#ff8f00');
    ctx.fillStyle=g;ctx.beginPath();ctx.arc(0,0,r,0,pi2);ctx.fill();
    ctx.shadowBlur=0;ctx.fillStyle='rgba(255,255,255,0.48)';ctx.beginPath();ctx.ellipse(-r*.22,-r*.28,r*.32,r*.18,-0.45,0,pi2);ctx.fill();
    ctx.fillStyle='rgba(120,70,0,0.8)';ctx.font=`bold ${r*1.15}px serif`;ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText('C',0,1);
  }
  ctx.restore();
}
function drawEnemy(e){
  ctx.save();ctx.translate(e.x,e.y);ctx.rotate(e.rot);
  ctx.shadowColor='#ff1744';ctx.shadowBlur=P.enemyMagT>0?28+Math.sin(t*10)*10:16;
  ctx.beginPath();for(let i=0;i<3;i++){const a=i*pi2/3;i===0?ctx.moveTo(Math.cos(a)*e.r,Math.sin(a)*e.r):ctx.lineTo(Math.cos(a)*e.r,Math.sin(a)*e.r);}ctx.closePath();
  const g=ctx.createRadialGradient(0,0,2,0,0,e.r);g.addColorStop(0,'#ff6d75');g.addColorStop(1,'#b71c1c');
  ctx.fillStyle=g;ctx.fill();ctx.strokeStyle='#ff8a80';ctx.lineWidth=1.5;ctx.stroke();
  ctx.shadowBlur=0;ctx.fillStyle='#fff';ctx.beginPath();ctx.arc(0,-2,4.5,0,pi2);ctx.fill();
  ctx.fillStyle='#111';ctx.beginPath();ctx.arc(1,-2,2.5,0,pi2);ctx.fill();ctx.restore();
}
function drawHeavyEnemy(e){
  ctx.save();ctx.translate(e.x,e.y);ctx.rotate(e.rot+Math.PI/4);
  ctx.shadowColor='#ff6d00';ctx.shadowBlur=20+Math.sin(t*5)*6;
  const s=e.r*1.1;
  ctx.beginPath();ctx.moveTo(0,-s);ctx.lineTo(s,0);ctx.lineTo(0,s);ctx.lineTo(-s,0);ctx.closePath();
  const g=ctx.createRadialGradient(0,0,2,0,0,s);g.addColorStop(0,'#ffab40');g.addColorStop(0.5,'#ff6d00');g.addColorStop(1,'#bf360c');
  ctx.fillStyle=g;ctx.fill();ctx.strokeStyle='#ffcc80';ctx.lineWidth=2;ctx.stroke();
  ctx.shadowBlur=0;ctx.rotate(-(e.rot+Math.PI/4));
  ctx.fillStyle='#fff';ctx.font='bold 13px "Segoe UI"';ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText('×2',0,0);
  ctx.restore();
}
function drawHealEnemy(e){
  ctx.save();ctx.translate(e.x,e.y);
  const pulse=1+Math.sin(t*4)*0.1;
  ctx.shadowColor='#00e676';ctx.shadowBlur=22+Math.sin(t*5)*8;
  ctx.beginPath();
  const s=e.r*pulse;
  ctx.moveTo(0,s*0.3);
  ctx.bezierCurveTo(s*1.0,-s*0.3,s*1.1,-s*1.0,0,-s*0.55);
  ctx.bezierCurveTo(-s*1.1,-s*1.0,-s*1.0,-s*0.3,0,s*0.3);
  ctx.closePath();
  const g=ctx.createRadialGradient(0,-s*0.1,2,0,0,s);
  g.addColorStop(0,'#b9f6ca');g.addColorStop(0.5,'#00e676');g.addColorStop(1,'#00695c');
  ctx.fillStyle=g;ctx.fill();ctx.strokeStyle='#69f0ae';ctx.lineWidth=2;ctx.stroke();
  ctx.shadowBlur=0;ctx.fillStyle='#fff';ctx.font=`bold ${e.r*0.72}px serif`;
  ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText('💚',0,2);
  ctx.restore();
}
function drawHeal2Enemy(e){
  ctx.save();ctx.translate(e.x,e.y);
  const pulse=1+Math.sin(t*4.5)*0.11;
  ctx.shadowColor='#ffd600';ctx.shadowBlur=24+Math.sin(t*5)*8;
  for(const ox of [-e.r*0.38,e.r*0.38]){
    ctx.beginPath();
    const s=e.r*pulse*0.72;
    ctx.moveTo(ox,s*0.3);
    ctx.bezierCurveTo(ox+s*1.0,-s*0.3,ox+s*1.1,-s*1.0,ox,-s*0.55);
    ctx.bezierCurveTo(ox-s*1.1,-s*1.0,ox-s*1.0,-s*0.3,ox,s*0.3);
    ctx.closePath();
    const g=ctx.createRadialGradient(ox,-s*0.1,1,ox,0,s);
    g.addColorStop(0,'#fffde7');g.addColorStop(0.5,'#ffd600');g.addColorStop(1,'#e65100');
    ctx.fillStyle=g;ctx.fill();ctx.strokeStyle='#fff176';ctx.lineWidth=1.5;ctx.stroke();
  }
  ctx.shadowBlur=0;ctx.fillStyle='#fff';ctx.font=`bold ${e.r*0.6}px serif`;
  ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText('💛',0,2);
  ctx.restore();
}
function drawFullHealEnemy(e){
  ctx.save();ctx.translate(e.x,e.y);
  const pulse=1+Math.sin(t*5)*0.13,hue=(t*80)%360;
  ctx.shadowColor=`hsl(${hue},100%,70%)`;ctx.shadowBlur=28+Math.sin(t*6)*10;
  ctx.beginPath();
  const s=e.r*pulse;
  ctx.moveTo(0,s*0.3);
  ctx.bezierCurveTo(s*1.0,-s*0.3,s*1.1,-s*1.0,0,-s*0.55);
  ctx.bezierCurveTo(-s*1.1,-s*1.0,-s*1.0,-s*0.3,0,s*0.3);
  ctx.closePath();
  const g=ctx.createRadialGradient(0,-s*0.1,2,0,0,s);
  g.addColorStop(0,'#fff');g.addColorStop(0.3,`hsl(${hue},100%,80%)`);
  g.addColorStop(0.7,`hsl(${(hue+120)%360},100%,55%)`);g.addColorStop(1,`hsl(${(hue+240)%360},100%,35%)`);
  ctx.fillStyle=g;ctx.fill();
  ctx.strokeStyle=`hsl(${(hue+60)%360},100%,85%)`;ctx.lineWidth=2.5;ctx.stroke();
  ctx.shadowBlur=0;ctx.fillStyle='#fff';ctx.font=`bold ${e.r*0.72}px serif`;
  ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText('💖',0,2);
  ctx.restore();
}
function drawDeathEnemy(e){
  ctx.save();ctx.translate(e.x,e.y);ctx.rotate(e.rot*0.6);
  const pulse=1+Math.sin(t*5)*0.12;ctx.shadowColor='#aa00ff';ctx.shadowBlur=28+Math.sin(t*6)*10;
  ctx.beginPath();for(let i=0;i<5;i++){const a=i*pi2/5-Math.PI/2;i===0?ctx.moveTo(Math.cos(a)*e.r*pulse,Math.sin(a)*e.r*pulse):ctx.lineTo(Math.cos(a)*e.r*pulse,Math.sin(a)*e.r*pulse);}ctx.closePath();
  const g=ctx.createRadialGradient(0,0,3,0,0,e.r);g.addColorStop(0,'#ce93d8');g.addColorStop(0.5,'#6a0080');g.addColorStop(1,'#0d0020');
  ctx.fillStyle=g;ctx.fill();ctx.strokeStyle='#ea80ff';ctx.lineWidth=2.5;ctx.stroke();
  ctx.shadowBlur=0;ctx.font=`${e.r*1.1}px serif`;ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText('💀',0,1);
  ctx.shadowColor='#aa00ff';ctx.shadowBlur=10;ctx.fillStyle='#fff';ctx.font='bold 12px "Segoe UI"';ctx.fillText('即　死',0,-(e.r+10));ctx.restore();
}
function drawPowerup(pw){
  const cols={magnet:'#2979ff',shield:'#00e676',speed:'#ffd600',heart:'#ff4081',enemymagnet:'#ff1744',armor:'#4fc3f7',bomb:'#ff3d00',freeze:'#80deea',instadeath:'#aa00ff',enemyfreeze:'#40c4ff',allbomb:'#ff6d00',randbox:'#ffd600'};
  const icons={magnet:'🧲',shield:'🛡',speed:'⚡',heart:'💖',enemymagnet:'😈',armor:'🔷',bomb:'💣',freeze:'❄',instadeath:'💀',enemyfreeze:'🧊',allbomb:'☄',randbox:'❓'};
  const pulse=1+Math.sin(pw.age*4)*0.11;
  ctx.save();ctx.translate(pw.x,pw.y);ctx.shadowColor=cols[pw.type];ctx.shadowBlur=24;
  ctx.beginPath();ctx.arc(0,0,pw.r*pulse,0,pi2);ctx.fillStyle=cols[pw.type]+'28';ctx.fill();
  ctx.strokeStyle=cols[pw.type];ctx.lineWidth=2.2;ctx.stroke();
  ctx.shadowBlur=0;ctx.font=`${pw.r*1.5}px serif`;ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText(icons[pw.type],0,1);
  if(pw.type==='armor'){ctx.fillStyle='#fff';ctx.font='bold 10px "Segoe UI"';ctx.fillText('×5',0,pw.r*0.9);}
  if(pw.type==='bomb'){const ring=1+Math.sin(pw.age*8)*0.3;ctx.strokeStyle='#ffab40';ctx.lineWidth=1.5;ctx.globalAlpha=0.5+Math.sin(pw.age*8)*0.4;ctx.beginPath();ctx.arc(0,0,pw.r*ring*1.5,0,pi2);ctx.stroke();ctx.globalAlpha=1;}
  if(pw.type==='allbomb'){const r1=1+Math.sin(pw.age*5)*0.35;ctx.strokeStyle='#ffff00';ctx.lineWidth=2;ctx.globalAlpha=0.55+Math.sin(pw.age*5)*0.3;ctx.beginPath();ctx.arc(0,0,pw.r*r1*1.7,0,pi2);ctx.stroke();const r2=1+Math.sin(pw.age*5+Math.PI)*0.35;ctx.strokeStyle='#ff6d00';ctx.lineWidth=1.5;ctx.globalAlpha=0.35+Math.sin(pw.age*5+Math.PI)*0.25;ctx.beginPath();ctx.arc(0,0,pw.r*r2*2.3,0,pi2);ctx.stroke();ctx.globalAlpha=1;}
  if(pw.type==='randbox'){const hue=(t*110+pw.age*60)%360;ctx.shadowColor=`hsl(${hue},100%,65%)`;ctx.shadowBlur=28;for(let ri=0;ri<3;ri++){const rh=(hue+ri*120)%360,rr=1+Math.sin(pw.age*5+ri*2.1)*0.28;ctx.strokeStyle=`hsl(${rh},100%,65%)`;ctx.lineWidth=1.8;ctx.globalAlpha=0.45+Math.sin(pw.age*4+ri)*0.3;ctx.beginPath();ctx.arc(0,0,pw.r*rr*(1.6+ri*0.4),0,pi2);ctx.stroke();}ctx.globalAlpha=1;ctx.shadowBlur=0;ctx.font=`${pw.r*1.8}px serif`;ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText('❓',0,1);}
  ctx.restore();
}
function drawPlayer(){
  const blink=P.invT>0&&Math.sin(t*20)>0; if(blink)return;
  ctx.save();ctx.translate(P.x,P.y);ctx.scale(P.sqX,P.sqY);
  if(P.armorCount>0){
    const ac=P.armorCount,acol=ac<=1?'#ff8a65':'#4fc3f7';
    ctx.save();ctx.shadowColor=acol;ctx.shadowBlur=14;ctx.globalAlpha=0.3+ac/5*0.55;
    ctx.strokeStyle=acol;ctx.lineWidth=2.5;ctx.beginPath();
    for(let i=0;i<6;i++){const a=i*pi2/6-Math.PI/6,r=P.r+13;i===0?ctx.moveTo(Math.cos(a)*r,Math.sin(a)*r):ctx.lineTo(Math.cos(a)*r,Math.sin(a)*r);}
    ctx.closePath();ctx.stroke();ctx.globalAlpha=1;ctx.shadowBlur=0;
    ctx.fillStyle=acol;ctx.font='bold 10px "Segoe UI"';ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText(ac,0,-(P.r+13));ctx.restore();
  }
  if(P.shieldT>0){ctx.shadowColor='#00e676';ctx.shadowBlur=22;ctx.beginPath();ctx.arc(0,0,P.r+9,0,pi2);ctx.strokeStyle='#00e676';ctx.lineWidth=2.5;ctx.stroke();}
  if(P.speedT>0){ctx.shadowColor='#ffd600';ctx.shadowBlur=18;}
  const g=ctx.createRadialGradient(-P.r*.3,-P.r*.32,2,0,0,P.r);g.addColorStop(0,'#80d8ff');g.addColorStop(.6,'#00b0ff');g.addColorStop(1,'#006db3');
  ctx.fillStyle=g;ctx.beginPath();ctx.arc(0,0,P.r,0,pi2);ctx.fill();
  ctx.shadowBlur=0;ctx.fillStyle='rgba(255,255,255,0.36)';ctx.beginPath();ctx.ellipse(-P.r*.22,-P.r*.3,P.r*.38,P.r*.2,-0.4,0,pi2);ctx.fill();
  const a=P.angle,perp=a+Math.PI/2,ed=P.r*.38;
  for(const[ex,ey] of [[Math.cos(a)*P.r*.28+Math.cos(perp)*ed*.55,Math.sin(a)*P.r*.28+Math.sin(perp)*ed*.55],[Math.cos(a)*P.r*.28-Math.cos(perp)*ed*.55,Math.sin(a)*P.r*.28-Math.sin(perp)*ed*.55]]){
    ctx.fillStyle='#fff';ctx.beginPath();ctx.arc(ex,ey,5,0,pi2);ctx.fill();
    ctx.fillStyle='#102040';ctx.beginPath();ctx.arc(ex+Math.cos(a)*1.5,ey+Math.sin(a)*1.5,3,0,pi2);ctx.fill();
  }
  if(P.freezeT>0){
    ctx.save();ctx.shadowColor='#80deea';ctx.shadowBlur=20;ctx.globalAlpha=0.55+Math.sin(t*8)*0.15;
    for(let ring=0;ring<2;ring++){
      const rot=t*(ring===0?1.5:-1.2),rr=P.r+8+ring*7,pts=6;
      ctx.strokeStyle=ring===0?'#80deea':'#b2ebf2';ctx.lineWidth=1.5;ctx.beginPath();
      for(let i=0;i<pts;i++){const ang=i*pi2/pts+rot;i===0?ctx.moveTo(Math.cos(ang)*rr,Math.sin(ang)*rr):ctx.lineTo(Math.cos(ang)*rr,Math.sin(ang)*rr);}
      ctx.closePath();ctx.stroke();
    }
    ctx.globalAlpha=1;ctx.shadowBlur=0;ctx.fillStyle='#80deea';ctx.font='bold 11px "Segoe UI"';ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText('❄'+Math.ceil(P.freezeT),0,-(P.r+20));
    ctx.restore();
  }
  ctx.restore();
}
function drawParticles(){
  for(const p of particles){ctx.save();ctx.globalAlpha=Math.max(0,p.life);ctx.shadowColor=p.col;ctx.shadowBlur=8;ctx.fillStyle=p.col;ctx.beginPath();ctx.arc(p.x,p.y,p.r*Math.max(0,p.life),0,pi2);ctx.fill();ctx.restore();}
}
function drawPopups(){
  ctx.save();ctx.textAlign='center';ctx.textBaseline='middle';
  for(const p of popups){ctx.globalAlpha=Math.max(0,p.life);ctx.shadowColor=p.col;ctx.shadowBlur=10;ctx.fillStyle=p.col;ctx.font=`bold ${p.life>0.5?18:14}px "Segoe UI"`;ctx.fillText(p.txt,p.x,p.y);}
  ctx.globalAlpha=1;ctx.shadowBlur=0;ctx.restore();
}

// ── Main loop ─────────────────────────────────
function loop(ts){
  if(over||paused)return;
  const dt=Math.min(lastTs?(ts-lastTs)/1000:0.016,0.05); lastTs=ts;
  update(dt);
  ctx.save();
  if(shakeT>0){const s=shakeT/0.38;ctx.translate(rnd(-9,9)*s,rnd(-9,9)*s);}
  drawBg();
  for(const pw of powerups)drawPowerup(pw);
  for(const c of coins)drawCoin(c);
  for(const e of enemies)e.instant?drawDeathEnemy(e):e.heavy?drawHeavyEnemy(e):e.fullHeal?drawFullHealEnemy(e):e.heal2?drawHeal2Enemy(e):e.heal?drawHealEnemy(e):drawEnemy(e);
  if(P.enemyFreezeT>0){for(const e of enemies){ctx.save();ctx.translate(e.x,e.y);ctx.globalAlpha=0.38+Math.sin(t*6)*0.08;ctx.shadowColor='#40c4ff';ctx.shadowBlur=18;ctx.beginPath();ctx.arc(0,0,e.r+4,0,Math.PI*2);ctx.fillStyle='#40c4ff';ctx.fill();ctx.globalAlpha=1;ctx.shadowBlur=0;ctx.fillStyle='#fff';ctx.font=`${e.r*0.9}px serif`;ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText('🧊',0,1);ctx.restore();}}
  drawParticles();drawPlayer();drawPopups();
  ctx.restore();drawHUD();
  rafId=requestAnimationFrame(loop);
}

// ── Input ─────────────────────────────────────
document.addEventListener('keydown',e=>{
  keys[e.code]=true;
  if(e.code==='KeyP'||e.code==='Escape'){togglePause();e.preventDefault();}
  if(e.code==='Space'&&(over||!started)){startGame();e.preventDefault();}
});
document.addEventListener('keyup',e=>{keys[e.code]=false;});
document.getElementById('ob').addEventListener('click',()=>{if(!started||over)startGame();else togglePause();});
document.getElementById('pbtn').addEventListener('click',togglePause);

// ── Rules ─────────────────────────────────────
let rulesOpen=false,pausedByRules=false;
function openRules(){rulesOpen=true;if(started&&!over&&!paused){pausedByRules=true;togglePause();}document.getElementById('rulesPanel').classList.add('show');}
function closeRules(){rulesOpen=false;document.getElementById('rulesPanel').classList.remove('show');if(pausedByRules){pausedByRules=false;togglePause();}}
document.getElementById('ruleBtn').addEventListener('click',openRules);
document.getElementById('rulesClose').addEventListener('click',closeRules);

ctx.fillStyle='#080816';ctx.fillRect(0,0,W,H);
</script>
