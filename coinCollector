function star5(cx,cy,ro,ri,n,a0){
  ctx.beginPath();
  for(let i=0;i<n*2;i++){const a=a0+i*Math.PI/n,r=i%2===0?ro:ri;i===0?ctx.moveTo(cx+Math.cos(a)*r,cy+Math.sin(a)*r):ctx.lineTo(cx+Math.cos(a)*r,cy+Math.sin(a)*r);}
  ctx.closePath();
}
