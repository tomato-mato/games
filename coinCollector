<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>コインコレクター (スマホ)</title>
<style>
* { margin:0; padding:0; box-sizing:border-box; }
html,body { width:100%; height:100%; background:#000; overflow:hidden; font-family:'Segoe UI','Yu Gothic UI',sans-serif; }
body { display:flex; align-items:center; justify-content:center; }
#wrap { position:fixed; transform-origin:top left; }
canvas { display:block; }
#ov {
  position:absolute; inset:0;
  display:flex; flex-direction:column; align-items:center; justify-content:center; gap:12px;
  background:rgba(4,4,20,0.88); backdrop-filter:blur(7px);
}
#ov.hide { display:none; }
#ov h2 { font-size:2.1rem; font-weight:900; letter-spacing:.22em; }
#ov p  { font-size:.92rem; color:rgba(255,255,255,.6); text-align:center; line-height:1.8; padding:0 20px; }
#ov button {
  margin-top:6px;
  background:linear-gradient(135deg,#6a11cb,#2575fc);
  border:none; border-radius:8px; color:#fff;
  font-size:1rem; font-weight:700; padding:14px 40px;
  cursor:pointer; letter-spacing:.1em;
}
#ov { z-index:20; }
#joy-base {
  position:absolute; bottom:30px; left:14px; z-index:10;
  width:210px; height:210px; border-radius:50%;
  background:radial-gradient(circle, rgba(255,255,255,0.07) 0%, rgba(255,255,255,0.02) 65%, transparent 100%);
  border:2.5px solid rgba(255,255,255,0.22);
  box-shadow:0 0 28px rgba(80,140,255,0.18), inset 0 0 24px rgba(80,140,255,0.07);
  touch-action:none; user-select:none; -webkit-user-select:none;
}
#joy-ring {
  position:absolute; inset:28px; border-radius:50%;
  border:1px solid rgba(255,255,255,0.11);
  pointer-events:none;
}
#joy-knob {
  position:absolute; top:50%; left:50%;
  width:92px; height:92px; border-radius:50%;
  transform:translate(-50%,-50%);
  background:radial-gradient(circle at 36% 30%, rgba(255,255,255,0.95), rgba(150,200,255,0.75) 42%, rgba(55,115,240,0.90));
  border:2.5px solid rgba(255,255,255,0.82);
  box-shadow:0 0 22px rgba(100,160,255,0.80), 0 0 8px rgba(100,160,255,0.45), 0 5px 12px rgba(0,0,0,0.45);
  pointer-events:none;
}
#ruleBtn {
  position:absolute; top:66px; right:8px; z-index:10;
  background:rgba(255,255,255,0.11); border:1.5px solid rgba(255,255,255,0.3);
  border-radius:6px; color:#fff; font-size:.85rem; font-weight:700;
  padding:7px 14px; cursor:pointer; touch-action:manipulation;
  font-family:'Segoe UI','Yu Gothic UI',sans-serif;
}
#rulesPanel {
  display:none; position:fixed; inset:0; z-index:300;
  background:rgba(0,0,10,0.88); backdrop-filter:blur(10px);
  align-items:center; justify-content:center;
}
#rulesPanel.show { display:flex; }
#rulesBox {
  background:rgba(8,8,24,0.98); border:1px solid rgba(255,255,255,0.14);
  border-radius:14px; padding:20px 22px; max-width:480px; width:92vw;
  max-height:84vh; overflow-y:auto; color:#fff;
  font-size:.84rem; line-height:1.7;
  font-family:'Segoe UI','Yu Gothic UI',sans-serif;
}
#rulesBox h3 { font-size:1.1rem; margin-bottom:12px; color:#ffd600; text-align:center; }
.rsec { margin-bottom:10px; }
.rsec > b { color:#00e5ff; font-size:.76rem; letter-spacing:.12em; display:block; margin-bottom:3px; }
.rsec table { width:100%; border-collapse:collapse; }
.rsec td { padding:1px 5px 1px 0; vertical-align:middle; }
.rsec td:first-child { width:26px; text-align:center; }
.rsec .pt { color:#ffd600; font-weight:700; text-align:right; white-space:nowrap; }
#rulesClose {
  display:block; margin:12px auto 0;
  background:linear-gradient(135deg,#6a11cb,#2575fc);
  border:none; border-radius:8px; color:#fff;
  font-size:.9rem; font-weight:700; padding:9px 32px; cursor:pointer;
  touch-action:manipulation;
}
#pbtn {
  position:absolute; bottom:8px; right:8px; z-index:10;
  width:68px; height:68px; border-radius:50%;
  background:rgba(255,255,255,0.13);
  border:2px solid rgba(255,255,255,0.35);
  color:#fff; font-size:1.5rem; cursor:pointer;
  display:flex; align-items:center; justify-content:center;
  touch-action:manipulation;
}
#portrait {
  display:none; position:fixed; inset:0; z-index:200;
  background:#000; flex-direction:column;
  align-items:center; justify-content:center; gap:16px;
  color:#fff; font-size:1.1rem; text-align:center;
}
@media (orientation:portrait) { #portrait { display:flex; } }
</style>
</head>
<body>
<div id="wrap">
  <canvas id="c"></canvas>
  <div id="ov">
    <h2 style="color:#ffd600">コインコレクター</h2>
    <p>コインに触れてスコアを稼ごう！<br>
       赤い三角にダメージ、💀 は即死！<br>
       <b style="color:#fff">左下のレバー</b> で移動</p>
    <button id="ob">ゲームスタート</button>
    <div id="rg" style="font-size:.78rem;opacity:.72;letter-spacing:.04em;text-align:center">
      <span style="color:#aaa">F</span> 100 &nbsp;/&nbsp;
      <span style="color:#00e5ff">B</span> 1,000 &nbsp;/&nbsp;
      <span style="color:#ffd600">A</span> 10,000 &nbsp;/&nbsp;
      <span style="color:#ff6d00">S</span> 100,000 &nbsp;/&nbsp;
      <span style="color:#ff00e5">SS</span> 1,000,000
    </div>
  </div>
  <div id="joy-base">
    <div id="joy-ring"></div>
    <div id="joy-knob"></div>
  </div>
  <button id="pbtn">⏸</button>
  <button id="ruleBtn">ルール</button>
</div>
<div id="rulesPanel">
  <div id="rulesBox">
    <h3>📖 ゲームルール</h3>
    <div class="rsec"><b>操作</b><table>
      <tr><td>🕹</td><td>左下のバーチャルレバーで移動（8方向・アナログ対応）</td></tr>
      <tr><td>⏸</td><td>右下ボタン でポーズ</td></tr>
    </table></div>
    <div class="rsec"><b>コイン（得点）</b><table>
      <tr><td>🟡</td><td>金コイン</td><td class="pt">+10pt</td></tr>
      <tr><td>🟢</td><td>緑コイン</td><td class="pt">+100pt</td></tr>
      <tr><td>🟣</td><td>紫コイン</td><td class="pt">+200pt</td></tr>
      <tr><td>⭐</td><td>星コイン</td><td class="pt">+30pt</td></tr>
      <tr><td>🌟</td><td>大きい星（40秒後〜）</td><td class="pt">+500pt</td></tr>
      <tr><td>💎</td><td>四角（30秒後〜）</td><td class="pt">+1000pt</td></tr>
    </table></div>
    <div class="rsec"><b>敵</b><table>
      <tr><td>🔴</td><td>赤い三角（通常）</td><td class="pt" style="color:#ff6d75">−1ライフ</td></tr>
      <tr><td>🟠</td><td>橙のダイヤ（重量）</td><td class="pt" style="color:#ff6d00">−2ライフ</td></tr>
      <tr><td>💀</td><td>紫の五角形（即死）※盾で−1に軽減</td><td class="pt" style="color:#ea80ff">即死！</td></tr>
      <tr><td>💚</td><td>緑のハート（回復敵）触れるとライフ+1（満タンなら+200pt）</td><td class="pt" style="color:#69f0ae">+1ライフ</td></tr>
      <tr><td>💛</td><td>黄色のハート（回復敵）触れるとライフ+2（満タンなら+400pt）</td><td class="pt" style="color:#ffd600">+2ライフ</td></tr>
      <tr><td>💖</td><td>虹のハート（全回復敵）触れるとライフ全回復（満タンなら+500pt）</td><td class="pt" style="color:#ff80ab">全回復！</td></tr>
    </table></div>
    <div class="rsec"><b>パワーアップ</b><table>
      <tr><td>🧲</td><td>マグネット — コイン自動回収（6秒）</td></tr>
      <tr><td>🛡</td><td>シールド — ダメージ無効（6秒）</td></tr>
      <tr><td>⚡</td><td>スピード — 移動速度×1.75（5秒）</td></tr>
      <tr><td>💖</td><td>回復 — ライフ+1（満タンなら+100pt）</td></tr>
      <tr><td>🔷</td><td>盾 — ダメージブロック×5回</td></tr>
      <tr><td>💣</td><td>爆弾 — 近くの敵を最大5体爆破</td></tr>
      <tr><td>❄</td><td>凍結 — 5秒間動けなくなる！（危険）</td></tr>
      <tr><td>💀</td><td>即死アイテム — 触れると即死！盾で−1に軽減（超危険）</td></tr>
      <tr><td>🧊</td><td>敵凍結 — 5秒間すべての敵の動きが止まる！</td></tr>
      <tr><td>😈</td><td>敵マグネット — 8秒間敵が追跡！</td></tr>
      <tr><td>☄</td><td>全滅ボム — 画面上の全敵を一掃！（各+150pt）レア出現</td></tr>
      <tr><td>❓</td><td>ミステリーボックス — 触れるとランダムアイテム2〜4個出現！（危険なものも…）</td></tr>
    </table></div>
    <div class="rsec"><b>ボーナスイベント</b><table>
      <tr><td>60秒</td><td>コイン50個出現</td></tr>
      <tr><td>120秒</td><td>大きい星×10</td></tr>
      <tr><td>180秒</td><td>大きい星×50</td></tr>
      <tr><td>240秒</td><td>四角×5</td></tr>
      <tr><td>300秒</td><td>四角×50</td></tr>
    </table></div>
    <div class="rsec"><b>ランク</b>
      <p style="margin-top:3px">
        <span style="color:#aaa">F</span> 100 ／ <span style="color:#00e5ff">B</span> 1,000 ／
        <span style="color:#ffd600">A</span> 10,000 ／ <span style="color:#ff6d00">S</span> 100,000 ／
        <span style="color:#ff00e5">SS</span> 1,000,000
      </p>
    </div>
    <button id="rulesClose">閉じる</button>
  </div>
</div>
<div id="portrait">
  <div style="font-size:3rem">📱</div>
  <div>スマホを<b>横向き</b>にしてください</div>
</div>

<script>
'use strict';

const H=560,HUD=58,PH=H-HUD;
const _sw=Math.max(window.innerWidth,window.innerHeight);
const _sh=Math.min(window.innerWidth,window.innerHeight);
const W=Math.max(800,Math.round(_sw/(_sh/H)));
const cv=document.getElementById('c');
cv.width=W; cv.height=H;
const ctx=cv.getContext('2d');
const wrap=document.getElementById('wrap');
let joyScale=1;

function resizeCanvas(){
  const sc=Math.min(window.innerWidth/W, window.innerHeight/H);
  joyScale=sc;
  wrap.style.transform=`scale(${sc})`;
  wrap.style.left=((window.innerWidth-W*sc)/2)+'px';
  wrap.style.top= ((window.innerHeight-H*sc)/2)+'px';
}
window.addEventListener('resize',resizeCanvas);
resizeCanvas();

// ── Helpers ───────────────────────────────────
const rnd=(a,b)=>Math.random()*(b-a)+a;
const getRank=s=>s>=1000000?['SS','#ff00e5','#ff80f0']:s>=100000?['S','#ff6d00','#ff9100']:s>=10000?['A','#ffd600','#fff176']:s>=1000?['B','#00e5ff','#80d8ff']:s>=100?['F','#aaaaaa','#eeeeee']:['','#fff','#fff'];
const RANK_ORDER=['','F','B','A','S','SS'];
const rankGT=(a,b)=>RANK_ORDER.indexOf(a)>RANK_ORDER.indexOf(b);
const dist=(ax,ay,bx,by)=>Math.hypot(ax-bx,ay-by);
const clamp=(v,lo,hi)=>Math.max(lo,Math.min(hi,v));
const lerp=(a,b,t)=>a+(b-a)*t;
const pi2=Math.PI*2;

// ── Joystick ──────────────────────────────────
const jbase=document.getElementById('joy-base');
const jknob=document.getElementById('joy-knob');
const joy={dx:0,dy:0,touchId:null};
const JR=64; // max displacement in canvas px

function joyUpdate(touch){
  const rect=jbase.getBoundingClientRect();
  const cx=rect.left+rect.width*0.5;
  const cy=rect.top +rect.height*0.5;
  let cdx=(touch.clientX-cx)/joyScale;
  let cdy=(touch.clientY-cy)/joyScale;
  const len=Math.hypot(cdx,cdy);
  if(len>JR){cdx=cdx/len*JR;cdy=cdy/len*JR;}
  jknob.style.transform=`translate(calc(-50% + ${cdx}px),calc(-50% + ${cdy}px))`;
  joy.dx=cdx/JR; joy.dy=cdy/JR;
}
function joyReset(){
  joy.dx=0; joy.dy=0; joy.touchId=null;
  jknob.style.transition='transform 0.14s cubic-bezier(0.25,0.46,0.45,0.94)';
  jknob.style.transform='translate(-50%,-50%)';
  setTimeout(()=>{jknob.style.transition='';},150);
}

jbase.addEventListener('touchstart',e=>{
  e.preventDefault();
  if(joy.touchId!==null) return;
  const touch=e.changedTouches[0];
  joy.touchId=touch.identifier;
  jknob.style.transition='';
  joyUpdate(touch);
},{passive:false});

document.addEventListener('touchmove',e=>{
  for(const touch of e.changedTouches){
    if(touch.identifier===joy.touchId){e.preventDefault();joyUpdate(touch);return;}
  }
},{passive:false});

document.addEventListener('touchend',e=>{
  for(const touch of e.changedTouches)
    if(touch.identifier===joy.touchId){joyReset();return;}
});
document.addEventListener('touchcancel',e=>{
  for(const touch of e.changedTouches)
    if(touch.identifier===joy.touchId){joyReset();return;}
});

// ── State ─────────────────────────────────────
let P,coins,enemies,particles,popups,powerups;
let score,best,lives,level,levelXP,bestLevel,bestTime,prevRank,bestRank;
let over,started,paused;
let t,coinTimer,enemyTimer,pwTimer,deathTimer,bigStarTimer,squareTimer,enemyMagTimer,heavyEnemyTimer,healEnemyTimer,heal2EnemyTimer,fullHealEnemyTimer,allBombTimer,randBoxTimer;
let bonusDone,bigStarBonusDone,bigStar2BonusDone,squareBonusDone,squareBonus2Done;
let lastTs,rafId,shakeT;
const keys={};

function mkPlayer(){
  return{x:W/2,y:HUD+PH/2,r:20,vx:0,vy:0,speed:210,angle:0,sqX:1,sqY:1,
         invT:0,magT:0,shieldT:0,speedT:0,enemyMagT:0,armorCount:0,freezeT:0,enemyFreezeT:0};
}
function safePos(md){
  let x,y,i=0;
  do{ x=rnd(30,W-30); y=rnd(HUD+30,H-30); i++; }
  while(dist(x,y,P.x,P.y)<(md||130)&&i<25);
  return[x,y];
}

// ── Spawners ──────────────────────────────────
function spawnCoin(){
  const r=Math.random();
  let type,radius;
  if     (r<0.07){type='purple';radius=12;}
  else if(r<0.20){type='green'; radius=11;}
  else if(r<0.30){type='star';  radius=14;}
  else           {type='coin';  radius=10;}
  const[x,y]=safePos(100);
  coins.push({x,y,r:radius,type,age:0,vx:0,vy:0});
}
function spawnEnemy(){
  const [x,y]=safePos(160),spd=rnd(70+level*14,110+level*18),a=rnd(0,pi2);
  enemies.push({x,y,r:16,vx:Math.cos(a)*spd,vy:Math.sin(a)*spd,rot:0});
}
function spawnHeavyEnemy(){
  const[x,y]=safePos(170),spd=rnd(55+level*10,90+level*14),a=rnd(0,pi2);
  enemies.push({x,y,r:20,vx:Math.cos(a)*spd,vy:Math.sin(a)*spd,rot:0,heavy:true});
}
function spawnHealEnemy(){
  const [x,y]=safePos(160),spd=rnd(50+level*8,80+level*12),a=rnd(0,pi2);
  enemies.push({x,y,r:18,vx:Math.cos(a)*spd,vy:Math.sin(a)*spd,rot:0,heal:true});
}
function spawnHeal2Enemy(){
  const [x,y]=safePos(160),spd=rnd(45+level*7,72+level*11),a=rnd(0,pi2);
  enemies.push({x,y,r:20,vx:Math.cos(a)*spd,vy:Math.sin(a)*spd,rot:0,heal2:true});
}
function spawnFullHealEnemy(){
  const [x,y]=safePos(160),spd=rnd(40+level*6,65+level*10),a=rnd(0,pi2);
  enemies.push({x,y,r:22,vx:Math.cos(a)*spd,vy:Math.sin(a)*spd,rot:0,fullHeal:true});
}
function spawnDeathEnemy(){
  const [x,y]=safePos(200),spd=rnd(45+level*8,75+level*10),a=rnd(0,pi2);
  enemies.push({x,y,r:26,vx:Math.cos(a)*spd,vy:Math.sin(a)*spd,rot:0,instant:true});
}
function spawnPower(){
  const [x,y]=safePos(120);
  const types=['magnet','shield','speed','armor','bomb','freeze','instadeath','enemyfreeze'];
  if(lives<3) types.push('heart','heart');
  powerups.push({x,y,r:15,type:types[0|rnd(0,types.length)],age:0});
}
function burst(x,y,col,n){
  for(let i=0;i<(n||10);i++){
    const a=rnd(0,pi2),sp=rnd(60,220);
    particles.push({x,y,vx:Math.cos(a)*sp,vy:Math.sin(a)*sp-60,r:rnd(2,5),col,life:1});
  }
}
function popup(x,y,txt,col){ popups.push({x,y,vy:-75,txt,col,life:1}); }

// ── Lifecycle ─────────────────────────────────
function startGame(){
  P=mkPlayer();
  coins=[];enemies=[];particles=[];popups=[];powerups=[];
  score=0;lives=3;level=1;levelXP=0;prevRank='';
  t=0;coinTimer=0;enemyTimer=10;pwTimer=18;deathTimer=25;
  bigStarTimer=40;squareTimer=30;enemyMagTimer=20;heavyEnemyTimer=15;healEnemyTimer=20;heal2EnemyTimer=32;fullHealEnemyTimer=45;allBombTimer=20;randBoxTimer=25;
  bonusDone=bigStarBonusDone=bigStar2BonusDone=squareBonusDone=squareBonus2Done=false;
  shakeT=0;over=false;started=true;paused=false;
  best    =+(localStorage.getItem('cc-best')||0);
  bestLevel=+(localStorage.getItem('cc-bestlv')||1);
  bestTime =+(localStorage.getItem('cc-besttime')||0);
  bestRank =  localStorage.getItem('cc-bestrank')||'';
  for(let i=0;i<6;i++) spawnCoin();
  document.getElementById('ov').classList.add('hide');
  cancelAnimationFrame(rafId); lastTs=null;
  rafId=requestAnimationFrame(loop);
}
function absorbWithArmor(){
  P.armorCount--;P.invT=1.2;shakeT=0.18;
  burst(P.x,P.y,'#4fc3f7',16);
  if(P.armorCount>0)popup(P.x,P.y-22,`🔷 ブロック！残り${P.armorCount}回`,'#4fc3f7');
  else{popup(P.x,P.y-22,'🔷 盾が壊れた！','#ff8a65');burst(P.x,P.y,'#ff8a65',20);shakeT=0.35;}
}
function onDamage(){
  if(P.invT>0||P.shieldT>0) return;
  if(P.armorCount>0){absorbWithArmor();return;}
  lives--; P.invT=2.4; shakeT=0.38;
  burst(P.x,P.y,'#ff1744',18); popup(P.x,P.y-20,'💥 ダメージ！','#ff6d75');
  if(lives<=0) endGame();
}
function onHeavyDamage(){
  if(P.invT>0)return;
  if(P.shieldT>0){onDamage();return;}
  if(P.armorCount>0){absorbWithArmor();return;}
  lives=Math.max(0,lives-2);P.invT=2.4;shakeT=0.52;
  burst(P.x,P.y,'#ff6d00',22);burst(P.x,P.y,'#ff1744',12);
  popup(P.x,P.y-20,'💢 2ダメージ！','#ff6d00');
  if(lives<=0)endGame();
}
function onInstantKill(){
  if(P.invT>0) return;
  if(P.armorCount>0){absorbWithArmor();return;}
  if(P.shieldT>0){onDamage();return;}
  lives=0; shakeT=0.7;
  burst(P.x,P.y,'#aa00ff',35); burst(P.x,P.y,'#220033',20);
  popup(P.x,P.y-24,'💀 即死！！','#ea80ff'); endGame();
}
function endGame(){
  over=true; joyReset();
  if(score>best){best=score;localStorage.setItem('cc-best',best);}
  if(level>bestLevel){bestLevel=level;localStorage.setItem('cc-bestlv',bestLevel);}
  if(t>bestTime){bestTime=t;localStorage.setItem('cc-besttime',bestTime);}
  const[endRank]=getRank(score);
  if(rankGT(endRank,bestRank)){bestRank=endRank;localStorage.setItem('cc-bestrank',bestRank);}
  showOv('GAME OVER','#ff1744',`スコア: ${score.toLocaleString()}　ベスト: ${best.toLocaleString()}`,'もう一度');
}
function showOv(title,col,msg,btn){
  const ov=document.getElementById('ov');
  ov.querySelector('h2').textContent=title;
  ov.querySelector('h2').style.color=col;
  ov.querySelector('p').innerHTML=msg;
  ov.querySelector('button').textContent=btn;
  ov.classList.remove('hide');
}
function togglePause(){
  if(!started||over) return;
  paused=!paused;
  if(paused){joyReset();showOv('⏸ PAUSE','#ffd600','タップして再開','再開');}
  else{document.getElementById('ov').classList.add('hide');lastTs=null;rafId=requestAnimationFrame(loop);}
}

// ── Update ────────────────────────────────────
function update(dt){
  t+=dt;
  const[curRank,,rankGlow]=getRank(score);
  if(curRank&&curRank!==prevRank){
    prevRank=curRank;
    popup(P.x,P.y-44,curRank+'ランク獲得！',rankGlow);
    burst(P.x,P.y,rankGlow,30); shakeT=Math.max(shakeT,0.3);
  }
  let dx=0,dy=0;
  if(P.freezeT<=0){
    dx=joy.dx; dy=joy.dy;
    if(keys.ArrowLeft||keys.KeyA)  dx-=1;
    if(keys.ArrowRight||keys.KeyD) dx+=1;
    if(keys.ArrowUp||keys.KeyW)    dy-=1;
    if(keys.ArrowDown||keys.KeyS)  dy+=1;
  }
  const dlen=Math.hypot(dx,dy); if(dlen>1){dx/=dlen;dy/=dlen;}
  const sp=P.speed*(P.speedT>0?1.75:1);
  P.vx=lerp(P.vx,dx*sp,0.22); P.vy=lerp(P.vy,dy*sp,0.22);
  P.x=clamp(P.x+P.vx*dt,P.r,W-P.r);
  P.y=clamp(P.y+P.vy*dt,HUD+P.r,H-P.r);
  if(dx||dy) P.angle=Math.atan2(dy,dx);
  const mv2=Math.hypot(P.vx,P.vy)/sp;
  P.sqX=lerp(P.sqX,dx||dy?1+mv2*.14:1,0.25);
  P.sqY=lerp(P.sqY,dx||dy?1-mv2*.09:1,0.25);

  if(P.invT>0)P.invT-=dt; if(P.magT>0)P.magT-=dt;
  if(P.shieldT>0)P.shieldT-=dt; if(P.speedT>0)P.speedT-=dt;
  if(P.enemyMagT>0)P.enemyMagT-=dt; if(P.freezeT>0)P.freezeT-=dt; if(P.enemyFreezeT>0)P.enemyFreezeT-=dt; if(shakeT>0)shakeT-=dt;

  coinTimer-=dt;
  if(coinTimer<=0){coinTimer=Math.max(1.0,2.4-level*0.1);if(coins.length<12)spawnCoin();}
  if(t>=enemyTimer){enemyTimer=t+Math.max(2.5,8-level*0.4);if(enemies.length<4+level)spawnEnemy();}
  if(t>=pwTimer){pwTimer=t+rnd(16,26);if(powerups.length<2)spawnPower();}
  if(t>=enemyMagTimer&&!powerups.some(p=>p.type==='enemymagnet')){
    enemyMagTimer=t+rnd(25,40);
    const[x,y]=safePos(130);
    powerups.push({x,y,r:15,type:'enemymagnet',age:0});
  }
  if(t>=randBoxTimer&&!powerups.some(p=>p.type==='randbox')){
    randBoxTimer=t+rnd(35,55);
    const[rbx,rby]=safePos(120);
    powerups.push({x:rbx,y:rby,r:16,type:'randbox',age:0});
  }
  if(t>=allBombTimer&&!powerups.some(p=>p.type==='allbomb')){
    allBombTimer=t+rnd(45,70);
    const[abx,aby]=safePos(130);
    powerups.push({x:abx,y:aby,r:18,type:'allbomb',age:0});
  }

  if(t>=60&&!bonusDone){
    bonusDone=true;
    for(let i=0;i<50;i++){const[bx,by]=safePos(40);const s=i<8;coins.push({x:bx,y:by,r:s?14:10,type:s?'star':'coin',age:rnd(0,3),vx:0,vy:0});}
    popup(W/2,HUD+PH/2,'🎉 ボーナス！コイン50個！','#ffd600');
    burst(W/2,HUD+PH/2,'#ffd600',60);burst(W/2,HUD+PH/2,'#ff9100',40);shakeT=0.3;
  }
  if(t>=120&&!bigStarBonusDone){
    bigStarBonusDone=true;
    for(let i=0;i<10;i++){const[bx,by]=safePos(50);coins.push({x:bx,y:by,r:30,type:'bigstar',age:rnd(0,pi2),vx:0,vy:0});}
    popup(W/2,HUD+PH/2,'⭐ 大スターボーナス！×10','#ffe57f');
    burst(W/2,HUD+PH/2,'#fff',80);burst(W/2,HUD+PH/2,'#ffd600',60);shakeT=0.5;
  }
  if(t>=180&&!bigStar2BonusDone){
    bigStar2BonusDone=true;
    for(let i=0;i<50;i++){const[bx,by]=safePos(40);coins.push({x:bx,y:by,r:30,type:'bigstar',age:rnd(0,pi2),vx:0,vy:0});}
    popup(W/2,HUD+PH/2,'🌟 メガスターボーナス！×50','#ffe57f');
    burst(W/2,HUD+PH/2,'#fff',100);burst(W/2,HUD+PH/2,'#ffd600',80);shakeT=0.7;
  }
  if(t>=240&&!squareBonusDone){
    squareBonusDone=true;
    for(let i=0;i<5;i++){const[bx,by]=safePos(60);coins.push({x:bx,y:by,r:28,type:'square',age:rnd(0,pi2),vx:0,vy:0});}
    popup(W/2,HUD+PH/2,'💎 スクエアボーナス！×5','#00e5ff');
    burst(W/2,HUD+PH/2,'#00e5ff',80);burst(W/2,HUD+PH/2,'#aa00ff',40);shakeT=0.6;
  }
  if(t>=300&&!squareBonus2Done){
    squareBonus2Done=true;
    for(let i=0;i<50;i++){const[bx,by]=safePos(40);coins.push({x:bx,y:by,r:28,type:'square',age:rnd(0,pi2),vx:0,vy:0});}
    popup(W/2,HUD+PH/2,'🔥 メガスクエアボーナス！×50','#00e5ff');
    burst(W/2,HUD+PH/2,'#00e5ff',100);burst(W/2,HUD+PH/2,'#aa00ff',60);shakeT=0.9;
  }
  if(t>=squareTimer){squareTimer=t+rnd(40,60);if(!coins.some(c=>c.type==='square')){const[x,y]=safePos(140);coins.push({x,y,r:28,type:'square',age:0,vx:0,vy:0});}}
  if(t>=bigStarTimer){bigStarTimer=t+rnd(45,70);if(!coins.some(c=>c.type==='bigstar')){const[x,y]=safePos(120);coins.push({x,y,r:30,type:'bigstar',age:0,vx:0,vy:0});}}
  if(t>=heavyEnemyTimer){heavyEnemyTimer=t+rnd(12,20);if(enemies.filter(e=>e.heavy).length<1+Math.floor(level/2))spawnHeavyEnemy();}
  if(t>=healEnemyTimer){healEnemyTimer=t+rnd(25,40);if(!enemies.some(e=>e.heal))spawnHealEnemy();}
  if(t>=heal2EnemyTimer){heal2EnemyTimer=t+rnd(35,55);if(!enemies.some(e=>e.heal2))spawnHeal2Enemy();}
  if(t>=fullHealEnemyTimer){fullHealEnemyTimer=t+rnd(50,80);if(!enemies.some(e=>e.fullHeal))spawnFullHealEnemy();}
  if(t>=deathTimer){deathTimer=t+rnd(35,50);if(enemies.filter(e=>e.instant).length<1+Math.floor(level/3))spawnDeathEnemy();}

  for(let i=coins.length-1;i>=0;i--){
    const c=coins[i]; c.age+=dt;
    if(P.magT>0){const d=dist(P.x,P.y,c.x,c.y)||1;c.vx+=(P.x-c.x)/d*700*dt;c.vy+=(P.y-c.y)/d*700*dt;const mv=Math.hypot(c.vx,c.vy);if(mv>450){c.vx=c.vx/mv*450;c.vy=c.vy/mv*450;}}
    else{c.vx*=0.88;c.vy*=0.88;}
    c.x+=c.vx*dt;c.y+=c.vy*dt;
    if(dist(P.x,P.y,c.x,c.y)<P.r+c.r){
      const pts=c.type==='square'?1000:c.type==='bigstar'?500:c.type==='purple'?200:c.type==='green'?100:c.type==='star'?30:10;
      score+=pts;levelXP+=pts;
      const bc=c.type==='square'?'#00e5ff':c.type==='bigstar'?'#fff':c.type==='purple'?'#ce93d8':c.type==='green'?'#69f0ae':c.type==='star'?'#ffd600':'#ffca28';
      burst(c.x,c.y,bc,c.type==='square'?60:c.type==='bigstar'?50:c.type==='purple'?14:c.type==='green'?12:c.type==='star'?20:10);
      if(c.type==='square'){burst(c.x,c.y,'#fff',40);burst(c.x,c.y,'#aa00ff',30);shakeT=0.4;}
      if(c.type==='bigstar'){burst(c.x,c.y,'#ffd600',30);burst(c.x,c.y,'#ff9100',20);}
      popup(c.x,c.y-12,'+'+pts,c.type==='square'?'#00e5ff':c.type==='bigstar'?'#ffe57f':c.type==='purple'?'#ce93d8':c.type==='green'?'#69f0ae':c.type==='star'?'#ffd600':'#fff');
      coins.splice(i,1);
      if(levelXP>=level*120){level++;levelXP=0;popup(P.x,P.y-30,'LEVEL UP!','#00e5ff');if(level>bestLevel){bestLevel=level;localStorage.setItem('cc-bestlv',bestLevel);}}
    }
  }

  for(const e of enemies){
    if(P.enemyFreezeT>0){e.rot+=dt*0.3;continue;}
    if(P.enemyMagT>0){const d=dist(P.x,P.y,e.x,e.y)||1;e.vx+=(P.x-e.x)/d*380*dt;e.vy+=(P.y-e.y)/d*380*dt;const sp2=Math.hypot(e.vx,e.vy),ms=180+level*22;if(sp2>ms){e.vx=e.vx/sp2*ms;e.vy=e.vy/sp2*ms;}}
    e.x+=e.vx*dt;e.y+=e.vy*dt;e.rot+=dt*2.5;
    if(e.x-e.r<0){e.x=e.r;e.vx=Math.abs(e.vx);} if(e.x+e.r>W){e.x=W-e.r;e.vx=-Math.abs(e.vx);}
    if(e.y-e.r<HUD){e.y=HUD+e.r;e.vy=Math.abs(e.vy);} if(e.y+e.r>H){e.y=H-e.r;e.vy=-Math.abs(e.vy);}
    if(dist(P.x,P.y,e.x,e.y)<P.r+e.r-4){
      if(e.heal){
        if(lives<3){lives++;burst(e.x,e.y,'#00e676',22);popup(e.x,e.y,'💚 回復！','#69f0ae');}
        else{score+=200;burst(e.x,e.y,'#69f0ae',18);popup(e.x,e.y,'+200 満タン！','#69f0ae');}
        shakeT=0.1;enemies.splice(enemies.indexOf(e),1);continue;
      }
      if(e.heal2){
        const gained=Math.min(2,3-lives);lives=Math.min(3,lives+2);
        burst(e.x,e.y,'#ffd600',26);burst(e.x,e.y,'#fffde7',14);
        if(gained>0)popup(e.x,e.y,'💛 ×2回復！','#ffd600');
        else{score+=400;popup(e.x,e.y,'+400 満タン！','#ffd600');}
        shakeT=0.12;enemies.splice(enemies.indexOf(e),1);continue;
      }
      if(e.fullHeal){
        const added=3-lives;lives=3;
        burst(e.x,e.y,'#ff80ab',30);burst(e.x,e.y,'#ffffff',16);
        popup(e.x,e.y,'💖 全回復！','#ff80ab');
        if(added===0)popup(e.x,e.y-28,'+500 満タン！','#ff80ab'),score+=500;
        shakeT=0.15;enemies.splice(enemies.indexOf(e),1);continue;
      }
      if(e.instant)onInstantKill();else if(e.heavy)onHeavyDamage();else onDamage();
    }
  }

  for(let i=powerups.length-1;i>=0;i--){
    const pw=powerups[i];pw.age+=dt;
    if(dist(P.x,P.y,pw.x,pw.y)<P.r+pw.r){
      switch(pw.type){
        case'magnet':P.magT=6;burst(pw.x,pw.y,'#2979ff',16);popup(pw.x,pw.y,'🧲 マグネット！','#82b1ff');break;
        case'shield':P.shieldT=6;burst(pw.x,pw.y,'#00e676',16);popup(pw.x,pw.y,'🛡 シールド！','#69f0ae');break;
        case'speed':P.speedT=5;burst(pw.x,pw.y,'#ffd600',16);popup(pw.x,pw.y,'⚡ スピード！','#ffff00');break;
        case'freeze':P.freezeT=5;burst(pw.x,pw.y,'#80deea',16);popup(pw.x,pw.y,'❄ 凍結！','#80deea');break;
        case'enemyfreeze':P.enemyFreezeT=5;burst(pw.x,pw.y,'#40c4ff',24);burst(pw.x,pw.y,'#ffffff',14);popup(pw.x,pw.y,'🧊 敵が凍った！5秒間停止！','#40c4ff');break;
        case'instadeath':onInstantKill();burst(pw.x,pw.y,'#aa00ff',40);burst(pw.x,pw.y,'#ff1744',20);popup(P.x,P.y-28,'💀 即死アイテム！','#ea80ff');break;
        case'heart':if(lives<3){lives++;burst(pw.x,pw.y,'#ff4081',20);popup(pw.x,pw.y,'💖 回復！','#ff80ab');}else{score+=100;popup(pw.x,pw.y,'+100 満タン！','#ff80ab');}break;
        case'armor':P.armorCount=5;burst(pw.x,pw.y,'#4fc3f7',20);popup(pw.x,pw.y,'🔷 盾装備！×5','#4fc3f7');break;
        case'bomb':{const targets=[...enemies].sort((a,b)=>dist(P.x,P.y,a.x,a.y)-dist(P.x,P.y,b.x,b.y)).slice(0,5);for(const e of targets){burst(e.x,e.y,'#ff6d00',28);burst(e.x,e.y,'#ffab40',18);burst(e.x,e.y,'#fff',10);score+=100;enemies.splice(enemies.indexOf(e),1);}burst(pw.x,pw.y,'#ff1744',35);burst(pw.x,pw.y,'#ffd600',25);shakeT=0.65;popup(P.x,P.y-34,`💣 ${targets.length}体爆破！`,'#ff6d00');break;}
        case'enemymagnet':P.enemyMagT=8;shakeT=0.3;burst(pw.x,pw.y,'#ff1744',20);popup(pw.x,pw.y,'😈 敵が引き寄せられた！','#ff6d00');break;
        case'randbox':{
          const pool=['magnet','shield','speed','heart','armor','bomb','enemyfreeze','magnet','shield','speed','heart'];
          if(Math.random()<0.22)pool.push('enemymagnet');
          if(Math.random()<0.15)pool.push('freeze');
          const cnt=2+Math.floor(Math.random()*3);
          for(let i=0;i<cnt;i++){const type=pool[0|rnd(0,pool.length)];const[rx,ry]=safePos(60);powerups.push({x:rx,y:ry,r:15,type,age:0});}
          burst(pw.x,pw.y,'#ffd600',35);burst(pw.x,pw.y,'#ff00e5',22);burst(pw.x,pw.y,'#00e5ff',18);
          shakeT=0.35;popup(pw.x,pw.y-22,`❓ ${cnt}個出現！`,'#ffd600');
          break;
        }
        case'allbomb':{const cnt=enemies.length;for(const e of [...enemies]){burst(e.x,e.y,'#ff6d00',24);burst(e.x,e.y,'#ffff00',16);burst(e.x,e.y,'#fff',8);score+=150;}enemies.length=0;burst(pw.x,pw.y,'#ff6d00',60);burst(pw.x,pw.y,'#ffff00',50);burst(pw.x,pw.y,'#fff',30);shakeT=0.9;popup(P.x,P.y-40,`☄ 全${cnt}体撃破！`,'#ffff00');break;}
      }
      powerups.splice(i,1);
    }
  }

  for(let i=particles.length-1;i>=0;i--){const p=particles[i];p.x+=p.vx*dt;p.y+=p.vy*dt;p.vy+=180*dt;p.vx*=0.97;p.life-=dt*1.7;if(p.life<=0)particles.splice(i,1);}
  for(let i=popups.length-1;i>=0;i--){const p=popups[i];p.y+=p.vy*dt;p.vy*=0.93;p.life-=dt*1.4;if(p.life<=0)popups.splice(i,1);}
}

